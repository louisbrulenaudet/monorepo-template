# Vite client env — only variables prefixed with VITE_ are exposed to the browser.
# Copy to `.env` / `.env.local` for local overrides (see .gitignore).
#
# Production / preview builds: set this to your deployed worker-api origin so the
# SPA can call the API. In development, the app defaults to http://localhost:8725
# when this is unset.
# VITE_WORKER_API_BASE_URL=https://api.example.com
