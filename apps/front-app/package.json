{
  "name": "front-app",
  "version": "0.0.0",
  "private": true,
  "description": "React SPA (Vite + TanStack Router/Query) deployed on Cloudflare; talks to worker-api over HTTP only.",
  "keywords": [
    "cloudflare",
    "frontend",
    "react",
    "spa",
    "tailwindcss",
    "tanstack-query",
    "tanstack-router",
    "vite"
  ],
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true vite build",
    "build": "tsc -b && vite build",
    "check": "oxfmt --check . && oxlint --no-error-on-unmatched-pattern .",
    "check-types": "tsc -b",
    "deploy": "wrangler deploy --env production",
    "dev": "vite",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "lint:fix": "oxlint --no-error-on-unmatched-pattern --fix .",
    "preview": "vite preview",
    "types": "wrangler types"
  },
  "dependencies": {
    "@repo/dtos-common": "workspace:*",
    "@repo/enums-common": "workspace:*",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@repo/typescript-config": "workspace:*",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/devtools-vite": "^0.8.1",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-plugin": "^1.168.19",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "^1.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "^8.1.4"
  },
  "monorepo": {
    "kind": "app",
    "role": "frontend",
    "prefix": "front-",
    "devPort": 5174,
    "agentGuide": "AGENTS.md"
  }
}
