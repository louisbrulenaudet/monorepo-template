{
  "name": "worker-api",
  "version": "0.0.0",
  "private": true,
  "description": "Public Hono HTTP gateway on Cloudflare Workers; validates requests with shared Zod contracts.",
  "keywords": [
    "api",
    "cloudflare-workers",
    "hono",
    "http-gateway",
    "worker",
    "zod"
  ],
  "main": "src/index.ts",
  "scripts": {
    "check": "oxfmt --check . && oxlint --no-error-on-unmatched-pattern .",
    "check-types": "tsc -b",
    "deploy": "wrangler deploy --env production",
    "dev": "wrangler dev",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "lint:fix": "oxlint --no-error-on-unmatched-pattern --fix .",
    "types": "wrangler types -c ./wrangler.jsonc"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.9.0",
    "@repo/dtos-common": "workspace:*",
    "@repo/enums-common": "workspace:*",
    "hono": "^4.12.30"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "monorepo": {
    "kind": "app",
    "role": "http-gateway",
    "prefix": "worker-",
    "devPort": 8700,
    "agentGuide": "AGENTS.md"
  }
}
