{
  "name": "worker-api",
  "version": "0.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "check": "oxfmt --check . && oxlint --no-error-on-unmatched-pattern --type-aware .",
    "check-types": "tsc --noEmit",
    "deploy": "wrangler deploy --env production --minify src/index.ts",
    "dev": "wrangler dev src/index.ts",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint --no-error-on-unmatched-pattern --type-aware .",
    "lint:fix": "oxlint --no-error-on-unmatched-pattern --type-aware --fix .",
    "types": "wrangler types -c ./wrangler.jsonc"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@repo/dtos-common": "workspace:*",
    "@repo/enums-common": "workspace:*",
    "hono": "^4.12.28"
  },
  "devDependencies": {
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0"
  }
}
