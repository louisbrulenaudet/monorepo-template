{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.rulers": [80],
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "always"
  },
  "oxc.path.oxlint": "node_modules/.bin/oxlint",
  "oxc.path.oxfmt": "node_modules/.bin/oxfmt",
  "oxc.configPath": ".oxlintrc.json",
  "oxc.fmt.configPath": ".oxfmtrc.json",
  "oxc.lint.run": "onType",
  "oxc.requireConfig": true,
  "oxc.typeAware": true,
  "oxc.unusedDisableDirectives": "deny",
  "oxc.fixKind": "safe_fix",
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never"
    }
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[markdown]": {
    "editor.formatOnSave": false,
    "files.trimTrailingWhitespace": false
  },
  "[yaml]": {
    "editor.formatOnSave": false
  },
  "[jsonc]": {
    "editor.formatOnSave": false
  },
  "editor.stickyScroll.enabled": true,
  "editor.stickyScroll.maxLineCount": 5,
  "editor.linkedEditing": true,
  "editor.guides.bracketPairs": "active",
  "editor.renderWhitespace": "trailing",
  "js/ts.experimental.useTsgo": true,
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.preferTypeOnlyAutoImports": true,
  "js/ts.preferences.autoImportFileExcludePatterns": [
    "**/worker-configuration.d.ts",
    "**/*.gen.ts",
    "**/dist/**",
    "**/.wrangler/**"
  ],
  // Low-noise inlay hints (helps read Zod/Hono/TanStack inferred types).
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.functionLikeReturnTypes.enabled": true,
  "js/ts.inlayHints.enumMemberValues.enabled": true,
  "tailwindCSS.experimental.configFile": {
    "apps/front-app/src/index.css": "apps/front-app/src/**"
  },
  "tailwindCSS.includeLanguages": {
    "typescript": "javascript",
    "typescriptreact": "javascript"
  },
  "files.associations": {
    "*.css": "tailwindcss",
    "wrangler.jsonc": "jsonc"
  },
  "json.schemas": [
    {
      "fileMatch": ["apps/*/wrangler.jsonc", "apps/*/wrangler.json"],
      "url": "./node_modules/wrangler/config-schema.json"
    }
  ],
  "vitest.configSearchPatternExclude": "{**/node_modules/**,**/vendor/**,**/.*/**,*.d.ts,**/vite.config.ts,**/vitest.config.ts,**/vitest.*.config.ts,**/dist/**,**/build/**}",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "files.eol": "\n",
  "files.readonlyInclude": {
    "**/worker-configuration.d.ts": true,
    "**/routeTree.gen.ts": true,
    "**/route-tree.gen.ts": true,
    "**/*.gen.ts": true,
    "pnpm-lock.yaml": true
  },
  "explorer.sortOrder": "foldersNestsFiles",
  "explorer.compactFolders": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "wrangler.jsonc": "wrangler.*.jsonc, worker-configuration.d.ts, .dev.vars, .dev.vars.*, .env, .env.*",
    ".oxlintrc.json": ".oxfmtrc.json",
    "vite.config.ts": "vite.config.*.ts, vitest.config.ts, vitest.*.config.ts, vitest.workspace.ts"
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/package-lock.json": true,
    "**/.turbo": true,
    "**/.wrangler": true,
    "**/dist": true,
    "**/build": true,
    "**/.vite": true,
    "**/.tanstack": true,
    "**/.vite-hmr": true,
    "**/.vitest": true,
    "**/coverage": true,
    "**/test-results": true,
    "**/.cache": true,
    "**/.tailwindcss": true,
    "**/preview": true,
    "**/*.tsbuildinfo": true,
    "**/.pnpm-store": true,
    "**/.husky/_": true,
    "**/.claude/worktrees": true,
    "**/.claude/logs": true,
    "**/.claude/agent-memory-local": true,
    "**/CLAUDE.local.md": true,
    "**/.staging.vars": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.turbo/**": true,
    "**/.wrangler/**": true,
    "**/dist/**": true,
    "**/build/**": true,
    "**/.vite/**": true,
    "**/.tanstack/**": true,
    "**/.vitest/**": true,
    "**/coverage/**": true,
    "**/test-results/**": true,
    "**/.cache/**": true,
    "**/.pnpm-store/**": true,
    "**/.claude/worktrees/**": true,
    "**/.claude/logs/**": true,
    "**/.claude/memories/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.turbo": true,
    "**/.wrangler": true,
    "**/dist": true,
    "**/build": true,
    "**/.vite": true,
    "**/.tanstack": true,
    "**/.vitest": true,
    "**/coverage": true,
    "**/test-results": true,
    "**/.cache": true,
    "**/.pnpm-store": true,
    "**/.claude/worktrees": true,
    "**/.claude/logs": true,
    "**/.claude/memories": true,
    "pnpm-lock.yaml": true
  },
  "search.useIgnoreFiles": true,
  "search.useGlobalIgnoreFiles": true,
  "search.followSymlinks": false,
  "search.smartCase": true,
  "npm.autoDetect": "off",
  "npm.packageManager": "pnpm",
  "cSpell.enabled": true,
  "cSpell.language": "en",
