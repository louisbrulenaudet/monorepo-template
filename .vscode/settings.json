{
  "makefile.configureOnOpen": false,
  "files.exclude": {
    "**/node_modules": true,
    "**/.turbo": true,
    "**/.wrangler": true,
    "**/.cache": true,
    "**/.vite": true
  },
  "files.associations": {
    "wrangler.json": "jsonc"
  },
  "editor.defaultFormatter": "biomejs.biome",
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit"
  },
  "[javascript][javascriptreact][typescript][typescriptreact][json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
