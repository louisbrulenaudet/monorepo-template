{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make ci)",
      "Bash(make check-types)",
      "Bash(make types)",
      "Bash(make lint)",
      "Bash(make format)",
      "Bash(make build)",
      "Bash(pnpm --filter * run check-types)",
      "Bash(pnpm --filter * test)",
      "Bash(pnpm --filter * exec tsc --noEmit)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(oxlint:*)",
      "Bash(oxfmt:*)",
      "Bash(turbo run:*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:oxc.rs)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:hono.dev)",
      "WebFetch(domain:cursor.com)",
      "WebFetch(domain:docs.cursor.com)",
      "WebFetch(domain:claude.com)",
      "WebFetch(domain:developer.mozilla.org)",
      "WebFetch(domain:turbo.build)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:zod.dev)",
      "WebFetch(domain:orm.drizzle.team)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:vite.dev)",
      "WebFetch(domain:pnpm.io)"
    ],
    "deny": [
      "Edit(**/dist/**)",
      "Edit(**/build/**)",
      "Edit(**/worker-configuration.d.ts)",
      "Edit(**/drizzle/migrations/**)",
      "Edit(**/pnpm-lock.yaml)",
      "Edit(pnpm-lock.yaml)",
      "Read(**/.dev.vars)",
      "Read(**/.dev.vars.local)",
      "Read(**/.dev.vars.staging)",
      "Read(**/.dev.vars.production)",
      "Read(**/.prod.vars)",
      "Read(**/.prod.vars.*)",
      "Read(**/.staging.vars)",
      "Read(**/.staging.vars.*)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.development)",
      "Read(**/.env.staging)",
      "Read(**/.env.test)",
      "Read(**/.env.production)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/credentials.json)",
      "Read(**/secrets.json)",
      "Edit(**/.dev.vars)",
      "Edit(**/.dev.vars.local)",
      "Edit(**/.dev.vars.staging)",
      "Edit(**/.dev.vars.production)",
      "Edit(**/.prod.vars)",
      "Edit(**/.prod.vars.*)",
      "Edit(**/.staging.vars)",
      "Edit(**/.staging.vars.*)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.development)",
      "Edit(**/.env.staging)",
      "Edit(**/.env.test)",
      "Edit(**/.env.production)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(**/*.p12)",
      "Edit(**/*.pfx)",
      "Edit(**/id_rsa)",
      "Edit(**/id_ed25519)",
      "Edit(**/credentials.json)",
      "Edit(**/secrets.json)"
    ],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hooks/git/guard-secret-commit.sh"
            ],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hooks/git/guard-destructive-git.sh"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hooks/quality/check-changed.sh"
            ],
            "timeout": 30
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hooks/logging/instructions-loaded.sh"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "credentials": {
      "files": [
        { "path": "~/.ssh", "mode": "deny" },
        { "path": "~/.aws", "mode": "deny" },
        { "path": "~/.config/.wrangler", "mode": "deny" },
        { "path": "~/.wrangler", "mode": "deny" }
      ]
    }
  },
  "autoMemoryEnabled": true,
  "enabledMcpjsonServers": [
    "cloudflare-docs",
    "context7"
  ],
  "enableAllProjectMcpServers": false
}
