{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(make ci)",
      "Bash(make check-types)",
      "Bash(make types)",
      "Bash(make lint)",
      "Bash(make format)",
      "Bash(make build)",
      "Bash(pnpm --filter * run check-types)",
      "Bash(pnpm --filter * test)",
      "Bash(pnpm --filter * exec tsc --noEmit)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(oxlint:*)",
      "Bash(oxfmt:*)",
      "Bash(turbo run:*)",
      "WebFetch(domain:code.claude.com)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:oxc.rs)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:vitest.dev)",
      "WebFetch(domain:hono.dev)"
    ],
    "deny": [
      "Edit(**/dist/**)",
      "Write(**/dist/**)",
      "Edit(**/worker-configuration.d.ts)",
      "Write(**/worker-configuration.d.ts)",
      "Read(**/.dev.vars)",
      "Read(**/.prod.vars)",
      "Read(**/.staging.vars)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hooks/git/guard-secret-commit.sh"
            ],
            "timeout": 10
          },
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hooks/git/guard-destructive-git.sh"
            ],
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hooks/quality/check-changed.sh"
            ],
            "timeout": 30
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "${CLAUDE_PROJECT_DIR}/hooks/logging/instructions-loaded.sh"
            ],
            "timeout": 10
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "security-guidance@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false
  },
  "autoMemoryEnabled": true,
  "enabledMcpjsonServers": [
    "cloudflare-docs",
    "context7"
  ],
  "enableAllProjectMcpServers": false
}
