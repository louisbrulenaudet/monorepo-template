{
  "name": "monorepo",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "check": "biome check --write .",
    "check-types": "turbo run check-types",
    "generate-types": "turbo run types --filter='./apps/*'",
