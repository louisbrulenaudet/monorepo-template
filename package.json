    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "cloc": "2.6.0-cloc",
    "cloudflare": "^5.2.0",
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.81.1"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=18"
