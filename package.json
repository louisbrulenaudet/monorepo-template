{
  "name": "monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "pnpm + Turborepo monorepo starter with Cloudflare Workers, Hono HTTP gateway, and React (Vite) frontend.",
  "keywords": [
    "cloudflare-workers",
    "hono",
    "monorepo",
    "pnpm",
    "react",
    "turborepo",
    "vite",
    "zod"
  ],
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run lint format",
    "check-types": "turbo run check-types",
    "check-types:solution": "tsc -b",
    "ci": "turbo run lint format check-types",
    "dev": "turbo run dev",
    "format": "turbo run format:fix",
    "format:fix": "oxfmt .",
    "lint": "turbo run lint:fix",
    "lint:agent": "oxlint --no-error-on-unmatched-pattern --format=agent .",
    "lint:fix": "oxlint --no-error-on-unmatched-pattern --fix .",
    "prepare": "husky",
    "types": "turbo run types --filter='./apps/*'",
    "update": "pnpm update --recursive --latest"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "26.1.1",
    "cloc": "2.6.0-cloc",
    "cloudflare": "^7.0.0",
    "eslint-plugin-better-tailwindcss": "^4.7.0",
    "git-format-staged": "^4.0.1",
    "husky": "^9.1.7",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "^7.0.2000",
    "tailwindcss": "catalog:",
    "turbo": "^2.10.5",
    "typescript": "catalog:",
    "wrangler": "^4.112.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.15.1",
  "monorepo": {
    "kind": "workspace",
    "role": "root",
    "agentGuide": "AGENTS.md"
  }
}
