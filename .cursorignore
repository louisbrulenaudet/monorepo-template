# Canonical ignore list is .gitignore; this file adds/overrides what Cursor must skip (lockfile, generated code, large artifacts).
# Cloudflare environment files
.dev.vars
.prod.vars
.staging.vars
.staging.vars.*

# Global environment files
.env
.env.development
.env.test
.env.production
.env.*
!.env.example

# Dependencies and build cache
node_modules/
.turbo/

# Generated TypeScript files
# Auto-generated by Wrangler from wrangler.jsonc - regenerated and shouldn't be analyzed
**/worker-configuration.d.ts

# Auto-generated by Vite - type definitions for Vite client
**/vite-env.d.ts

# Database migrations
# Drizzle migration SQL files and JSON snapshots - generated artifacts
**/drizzle/migrations/**

# Build outputs and cache
**/.wrangler/
**/dist/
**/build/
**/*.tsbuildinfo
**/.tsbuildinfo
**/tsconfig.tsbuildinfo

# Vite development cache - regenerated on each dev run
.vite/

# Source maps - generated during builds, not needed for analysis
*.map
**/*.map
*.d.ts.map

# Vite preview build artifacts
**/preview/

# Vite HMR (Hot Module Replacement) files
**/.vite-hmr/

# Lock files
# Very large dependency lock files (thousands of lines) - don't need code analysis
pnpm-lock.yaml
package-lock.json
yarn.lock
bun.lockb
# Package manager cache
.pnpm-store/
# Yarn v2+ files
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
.pnp
.pnp.js
# npm pack output
*.tgz

# Test coverage
**/coverage/
**/.nyc_output/
*.lcov
# Test artifacts and cache
**/.vitest/
**/test-results/
**/playwright-report/
**/playwright/.cache/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*
# Node.js diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
# Runtime data
*.pid
*.seed
*.pid.lock

# OS and editor files
.DS_Store
._*
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.directory
*.swp
*.swo
*~
.vscode/
.vscode-test
.idea/
*.sublime-*
.vim/

# Documentation build outputs
**/docs/build/
**/.next/
# Vercel (if used)
.vercel/

# Temporary files
*.tmp
*.temp
.cache/
**/.cache/
**/.parcel-cache/
**/.eslintcache
.stylelintcache

# Node REPL history
.node_repl_history

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Biome cache
.biome/

# Tailwind CSS cache (v4+)
.tailwindcss/

# TypeScript incremental build in node_modules
**/node_modules/.tmp/

# Husky internal files
.husky/_/

# Cloudflare backup files
wrangler.toml.bak
wrangler.jsonc.bak
# Security keys (PEM files)
*.pem
