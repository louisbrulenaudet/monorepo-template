# EditorConfig - cross-editor baseline, mirrors .oxfmtrc.json
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 80

# Markdown: preserve two-space hard line breaks
[*.md]
trim_trailing_whitespace = false

# Makefiles require real tabs
[{Makefile,makefile,*.mk}]
indent_style = tab
