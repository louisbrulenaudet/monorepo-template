# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Cloudflare environment files
.dev.vars
.dev.vars.*
.prod.vars
.prod.vars.*
.staging.vars
.staging.vars.*
!.dev.vars.example

# Global environment files
.env
.env.local
.env.development
.env.test
.env.production
.env.*
!.env.example
!.env.production.example

# Dependencies and build cache
node_modules/
.pnp
.pnp.js
.turbo/

# Generated TypeScript files
# Auto-generated by Wrangler from wrangler.jsonc - regenerated and shouldn't be committed
**/worker-configuration.d.ts

# Database migrations (e.g. Drizzle) - generated artifacts if added later
**/drizzle/migrations/**

# Astro - generated content collections and types
**/.astro/

# Build outputs and cache
**/.wrangler/
**/dist/
**/build/
**/*.tsbuildinfo
**/.tsbuildinfo
**/tsconfig.tsbuildinfo

# Flue dev cache (flue dev --target cloudflare)
**/.flue-vite/
**/.flue-vite.wrangler.jsonc

# Vite development cache - regenerated on each dev run
.vite/

# TanStack Router generator temp cache (atomic writes via router-plugin)
**/.tanstack/

# Source maps - generated during builds, not needed in repository
*.map
*.d.ts.map

# Vite preview build artifacts
**/preview/

# Vite HMR (Hot Module Replacement) files
**/.vite-hmr/

# Other lockfiles (we use pnpm; pnpm-lock.yaml is committed)
package-lock.json
yarn.lock
bun.lockb

# Package manager cache
.pnpm-store/

# Yarn v2+ files
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# npm pack output
*.tgz

# Test coverage
**/coverage/
**/.nyc_output/
*.lcov

# Test artifacts and cache
**/.vitest/
**/test-results/
**/playwright-report/
**/playwright/.cache/

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Node.js diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
*.pid
*.seed
*.pid.lock

# OS and editor files
.DS_Store
**/.DS_Store
._*
Thumbs.db
desktop.ini
$RECYCLE.BIN/
.directory
*.swp
*.swo
*~
.vscode-test
.idea/
*.sublime-*
.vim/

# Documentation build outputs
**/docs/build/
**/.next/
out/

# Vercel (if used)
.vercel/

# Temporary files
*.tmp
*.temp
.cache/
**/.cache/
**/.parcel-cache/
**/.eslintcache
.stylelintcache

# Node REPL history
.node_repl_history

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Tailwind CSS cache (v4+)
.tailwindcss/

# TypeScript incremental build in node_modules
**/node_modules/.tmp/

# Husky internal files
.husky/_/

# Claude Code personal project overrides (see code.claude.com/docs/en/memory)
CLAUDE.local.md

# Personal, per-developer agent settings (allowlist / tokens / paths) - never committed
.claude/settings.local.json
.cursor/settings.local.json

# Claude Code git worktrees (claude --worktree) - never commit worktree checkouts
.claude/worktrees/

# Agent debug logs (hooks)
hooks/logs/

# Cloudflare backup files
wrangler.toml.bak
wrangler.jsonc.bak

# Security keys & certificates (private keys must never be committed; the agent
# commit-guard and .cursorignore already block these - this closes the human-commit path too)
*.pem
*.key
id_rsa
id_ed25519
id_ecdsa
*.p12
*.pfx
