{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "hooks/git/guard-secret-commit.sh",
        "matcher": "Shell",
        "timeout": 10,
        "failClosed": true
      },
      {
        "command": "hooks/git/guard-destructive-git.sh",
        "matcher": "Shell",
        "timeout": 10,
        "failClosed": true
      }
    ],
    "postToolUse": [
      {
        "command": "hooks/quality/check-changed.sh",
        "matcher": "Write",
        "timeout": 30
      }
    ],
    "sessionStart": [
      {
        "command": "hooks/logging/session-start.sh",
        "timeout": 10
      }
    ]
  }
}
