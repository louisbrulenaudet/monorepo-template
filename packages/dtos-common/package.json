{
  "name": "@repo/dtos-common",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod wire contracts for HTTP, RPC, queue, and webhook boundaries.",
  "keywords": [
    "api",
    "contracts",
    "dto",
    "queue",
    "rpc",
    "shared",
    "webhook",
    "zod"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api/index.ts",
    "./rpc": "./src/rpc/index.ts",
    "./queue": "./src/queue/index.ts",
    "./webhook": "./src/webhook/index.ts"
  },
  "scripts": {
    "check": "oxfmt --check . && oxlint --no-error-on-unmatched-pattern .",
    "check-types": "tsc -b",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "lint:fix": "oxlint --no-error-on-unmatched-pattern --fix ."
  },
  "dependencies": {
    "@repo/enums-common": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "monorepo": {
    "kind": "library",
    "role": "contracts",
    "agentGuide": "AGENTS.md"
  }
}
