{
  "name": "@repo/typescript-config",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "sideEffects": false,
  "exports": {
    "./base.json": "./base.json",
    "./workers.json": "./workers.json",
    "./workers-lib.json": "./workers-lib.json",
    "./vite-react.json": "./vite-react.json",
    "./vite-node.json": "./vite-node.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check": "oxfmt --check . && oxlint --no-error-on-unmatched-pattern --type-aware .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint --no-error-on-unmatched-pattern --type-aware .",
    "lint:fix": "oxlint --no-error-on-unmatched-pattern --type-aware --fix ."
  },
  "devDependencies": {
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0"
  }
}
