{
  "name": "@repo/enums-common",
  "version": "0.0.0",
  "private": true,
  "description": "Shared constrained string values (`as const` objects) for dtos-common, workers, and front-app.",
  "keywords": [
    "contracts",
    "enums",
    "shared",
    "typescript"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "check-types": "tsc -b",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint --no-error-on-unmatched-pattern .",
    "lint:fix": "oxlint --no-error-on-unmatched-pattern --fix ."
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:"
  },
  "monorepo": {
    "kind": "library",
    "role": "enums",
    "agentGuide": "AGENTS.md"
  }
}
